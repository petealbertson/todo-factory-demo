<div id="<%= dom_id todo %>" class="<%= todo_due_classes(todo) %>">
  <div>
    <strong>Title:</strong>
    <%= todo.title %>
  </div>

  <div>
    <strong>Completed:</strong>
    <%= todo.completed %>
    <%= button_to "Toggle complete", toggle_todo_path(todo),
          method: :patch,
          form_class: "toggle-complete",
          aria: { label: "Toggle complete for #{todo.title}" } %>
  </div>

  <div>
    <%= button_to "Delete", todo, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
  </div>

  <% if todo.due_on.present? %>
    <div>
      <strong>Due:</strong>
      <%= todo.due_on %>
      <% if todo.overdue? %>
        <em>(overdue)</em>
      <% end %>
    </div>
  <% end %>

</div>
